import React, { useState, useRef } from 'react';

export default function App() {
  const [apiKey, setApiKey] = useState('');
  const [prompt, setPrompt] = useState('');
  const [generatedCode, setGeneratedCode] = useState('');
  const [isLoading, setIsLoading] = useState(false);
  const [activeTab, setActiveTab] = useState('preview'); // 'preview' or 'code'
  const [error, setError] = useState('');

  // System instructions forcing Gemini to return ONLY clean, self-contained web code
  const SYSTEM_PROMPT = `
    You are an expert autonomous full-stack software engineer. 
    Your task is to build a complete, beautiful, fully working single-file web application based on the user's request.
    
    CRITICAL RULES:
    1. Return ONLY valid, self-contained HTML.
    2. Include all CSS inside a <style> tag in the <head>.
    3. Include all interactive JavaScript logic inside a <script> tag before the closing </body> tag.
    4. Use modern, clean UI styling (prefer modern fonts, good padding, clean layout, dark themes if requested).
    5. Ensure all interactive features (buttons, forms, counters, calculations) work perfectly with vanilla JavaScript.
    6. Do NOT include any explanations, introduction, or markdown wrapping outside of standard code blocks. Just output the clean code.
  `;

  const handleGenerate = async () => {
    if (!apiKey) {
      setError('Please enter your free Gemini API Key first.');
      return;
    }
    if (!prompt) {
      setError('Please enter a description of what you want to build.');
      return;
    }

    setIsLoading(true);
    setError('');
    setGeneratedCode('// Architecting software layout...\n// Writing clean HTML/CSS...\n// Injecting interactive JavaScript...');

    try {
      // Standard fetch directly to the Google Gemini 2.5 Flash API endpoint
      const response = await fetch(
        `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${apiKey}`,
        {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            contents: [
              {
                parts: [
                  { text: `${SYSTEM_PROMPT}\n\nUser Request: ${prompt}` }
                ]
              }
            ],
            generationConfig: {
              temperature: 0.2, // Lower temperature means more structured, less chaotic code
            }
          })
        }
      );

      const data = await response.json();
      
      if (!response.ok) {
        throw new Error(data.error?.message || 'Failed to communicate with Gemini API');
      }

      let rawCode = data.candidates[0].content.parts[0].text;

      // Clean up markdown formatting if Gemini accidentially adds ```html ... ``` fences
      let cleanCode = rawCode
        .replace(/```html/gi, '')
        .replace(/```javascript/gi, '')
        .replace(/```/g, '')
        .trim();

      setGeneratedCode(cleanCode);
      setActiveTab('preview');
    } catch (err) {
      setError(err.message || 'An unexpected error occurred.');
      setGeneratedCode('');
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <div style={styles.container}>
      {/* Top Navbar */}
      <header style={styles.header}>
        <div style={styles.logoZone}>
          <span style={styles.logoIcon}>🤖</span>
          <h1 style={styles.logoText}>PromptCraft MVP</h1>
        </div>
        <div style={styles.apiZone}>
          <input
            type="password"
            placeholder="Paste Gemini API Key here"
            value={apiKey}
            onChange={(e) => setApiKey(e.target.value)}
            style={styles.apiKeyInput}
          />
          <a 
            href="[https://aistudio.google.com/](https://aistudio.google.com/)" 
            target="_blank" 
            rel="noreferrer" 
            style={styles.apiLink}
          >
            Get Free Key
          </a>
        </div>
      </header>

      {/* Main Workspace Workspace */}
      <main style={styles.workspace}>
        
        {/* Left Side: Controls & Input */}
        <section style={styles.leftPanel}>
          <div style={styles.inputContainer}>
            <label style={styles.label}>What do you want to build?</label>
            <textarea
              placeholder="e.g., Build a gorgeous dark-themed Pomodoro timer with custom interval inputs, a live countdown, and a sound notification when done."
              value={prompt}
              onChange={(e) => setPrompt(e.target.value)}
              style={styles.textarea}
              disabled={isLoading}
            />
            <button
              onClick={handleGenerate}
              disabled={isLoading}
              style={isLoading ? { ...styles.button, ...styles.buttonDisabled } : styles.button}
            >
              {isLoading ? 'Engineering App...' : 'Compile & Run App ⚡'}
            </button>
            {error && <p style={styles.errorText}>{error}</p>}
          </div>

          {/* Code Viewer Mode Toggle */}
          <div style={styles.codeViewHeader}>
            <span style={{fontWeight: 'bold', color: '#a9b2c3'}}>Source Engine Output</span>
            <button 
              style={styles.toggleBtn} 
              onClick={() => setActiveTab(activeTab === 'preview' ? 'code' : 'preview')}
            >
              {activeTab === 'preview' ? 'Show Raw Code' : 'Show Live Screen'}
            </button>
          </div>
          <pre style={styles.codeBox}>
            <code>{generatedCode || '// Your generated application code will display here...'}</code>
          </pre>
        </section>

        {/* Right Side: Virtual Sandbox App Runner */}
        <section style={styles.rightPanel}>
          <div style={styles.panelHeader}>
            <div style={styles.tabGroup}>
              <button 
                style={activeTab === 'preview' ? { ...styles.tab, ...styles.activeTab } : styles.tab}
                onClick={() => setActiveTab('preview')}
              >
                🌐 Live App Running Sandbox
              </button>
              <button 
                style={activeTab === 'code' ? { ...styles.tab, ...styles.activeTab } : styles.tab}
                onClick={() => setActiveTab('code')}
              >
                🛠️ Full-Screen Code Inspector
              </button>
            </div>
            <div style={styles.windowControls}>
              <span style={{...styles.dot, backgroundColor: '#ff5f56'}}></span>
              <span style={{...styles.dot, backgroundColor: '#ffbd2e'}}></span>
              <span style={{...styles.dot, backgroundColor: '#27c93f'}}></span>
            </div>
          </div>

          <div style={styles.screenBody}>
            {activeTab === 'preview' ? (
              generatedCode && !isLoading ? (
                <iframe
                  title="App Sandbox Execution"
                  srcDoc={generatedCode}
                  sandbox="allow-scripts"
                  style={styles.iframeSandbox}
                />
              ) : (
                <div style={styles.emptySandbox}>
                  <p style={{fontSize: '24px', marginBottom: '8px'}}>🖥️ Virtual Web Container</p>
                  <p style={{color: '#6b7280', textAlign: 'center', maxWidth: '300px'}}>
                    Type a prompt on the left and hit compile to instantly run software inside this sandboxed container.
                  </p>
                </div>
              )
            ) : (
              <textarea 
                readOnly 
                value={generatedCode} 
                style={styles.fullscreenCode}
              />
            )}
          </div>
        </section>

      </main>
    </div>
  );
}

